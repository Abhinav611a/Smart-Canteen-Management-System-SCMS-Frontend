# Copy this to .env.local and adjust for your environment

# Backend URL (deployed on Render.com)
VITE_BACKEND_URL=https://smart-canteen-backend-k235.onrender.com

# Cloudinary unsigned uploads for admin menu images
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset_name

# For local development, override with:
# VITE_BACKEND_URL=http://localhost:8080
